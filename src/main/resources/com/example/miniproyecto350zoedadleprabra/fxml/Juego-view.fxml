<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.miniproyecto350zoedadleprabra.controller.JuegoController"
           stylesheets="@/com/example/miniproyecto350zoedadleprabra/css/styles.css">

    <!-- Mesa de juego como fondo -->
    <ImageView fx:id="imgMesa" fitHeight="720" fitWidth="1280" pickOnBounds="true">
        <image>
            <Image url="@/com/example/miniproyecto350zoedadleprabra/images/ui/GameBG.png"/>
        </image>
    </ImageView>

    <!-- Contenedor principal -->
    <AnchorPane fx:id="panelPrincipal" prefHeight="720" prefWidth="1280">

        <!-- ============================================ -->
        <!-- ZONA SUPERIOR: Información y temporizador -->
        <!-- ============================================ -->
        <HBox alignment="CENTER_LEFT" spacing="20"
              AnchorPane.leftAnchor="20" AnchorPane.topAnchor="10">

            <!-- Panel de suma de mesa -->
            <StackPane style="-fx-background-color: rgba(0, 0, 0, 0.7);
                              -fx-background-radius: 15;
                              -fx-border-color: #DAA520;
                              -fx-border-width: 2;
                              -fx-border-radius: 15;">
                <padding>
                    <Insets bottom="10" left="20" right="20" top="10"/>
                </padding>
                <Label fx:id="lblSumaMesa"
                       text="50"
                       textFill="#FFD700"
                       style="-fx-font-size: 32px; -fx-font-weight: bold;">
                    <font>
                        <Font name="System Bold" size="32"/>
                    </font>
                </Label>
            </StackPane>

            <!-- Temporizador visual -->
            <StackPane fx:id="panelTemporizador" visible="false">
                <ImageView fx:id="imgContadorVacio"
                           fitHeight="60" fitWidth="80" preserveRatio="true">
                    <image>
                        <Image url="@/com/example/miniproyecto350zoedadleprabra/images/ui/bomb.png"/>
                    </image>
                </ImageView>
                <Label fx:id="lblTiempo"
                       text="5"
                       textFill="#FF0000"
                       style="-fx-font-size: 28px; -fx-font-weight: bold;"
                       alignment="CENTER"/>
            </StackPane>
        </HBox>

        <!-- Turno actual -->
        <Label fx:id="lblTurnoActual"
               textFill="#FFD700"
               style="-fx-font-size: 16px; -fx-background-color: rgba(0,0,0,0.7);
                      -fx-padding: 5 15; -fx-background-radius: 10;"
               AnchorPane.rightAnchor="20" AnchorPane.topAnchor="15"/>

        <!-- ============================================ -->
        <!-- ZONA CENTRAL: Carta en mesa y mazo -->
        <!-- ============================================ -->

        <!-- Carta actual en la mesa (centro) -->
        <StackPane fx:id="panelCartaMesa"
                   AnchorPane.centerXAnchor="0" AnchorPane.centerYAnchor="-50">
            <ImageView fx:id="imgCartaMesa"
                       fitHeight="190" fitWidth="142" preserveRatio="true"/>
            <!-- Efecto de brillo alrededor de la carta -->
            <ImageView fitHeight="210" fitWidth="160" opacity="0.3">
                <image>
                    <Image url="@../../../../resources/imagenes/ui/brillo_carta.png"/>
                </image>
            </ImageView>
        </StackPane>

        <!-- Mazo de cartas (derecha del centro) -->
        <VBox alignment="CENTER" spacing="5"
              AnchorPane.rightAnchor="150" AnchorPane.centerYAnchor="-50">
            <StackPane>
                <!-- Efecto de pila de cartas -->
                <ImageView fitHeight="190" fitWidth="142"
                           translateX="-3" translateY="-3" opacity="0.6">
                    <image>
                        <Image url="@/com/example/miniproyecto350zoedadleprabra/images/cartas/reverse.png"/>
                    </image>
                </ImageView>
                <ImageView fitHeight="190" fitWidth="142"
                           translateX="-1" translateY="-1" opacity="0.8">
                    <image>
                        <Image url="@/com/example/miniproyecto350zoedadleprabra/images/cartas/reverse.png"/>
                    </image>
                </ImageView>
                <ImageView fx:id="imgMazo"
                           fitHeight="190" fitWidth="142"
                           onMouseClicked="#tomarCartaMazo"
                           style="-fx-cursor: hand;">
                    <image>
                        <Image url="@/com/example/miniproyecto350zoedadleprabra/images/cartas/reverse.png"/>
                    </image>
                </ImageView>
            </StackPane>
            <Label text="MAZO"
                   textFill="#FFD700"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                          -fx-background-color: rgba(0,0,0,0.7);
                          -fx-padding: 2 10; -fx-background-radius: 8;"/>
        </VBox>

        <!-- ============================================ -->
        <!-- ZONA INFERIOR: Mano del jugador humano -->
        <!-- ============================================ -->
        <VBox alignment="CENTER" spacing="10"
              AnchorPane.bottomAnchor="20"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">


            <!-- Contenedor de cartas del humano -->
            <HBox fx:id="panelManoHumano"
                  alignment="CENTER" spacing="10"
                  style="-fx-padding: 10;
                         -fx-background-color: rgba(0, 0, 0, 0.3);
                         -fx-background-radius: 15;"
                  minHeight="210"/>

            <!-- Botones de acción -->
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="btnRendirse"
                        text="RENDIRSE"
                        style="-fx-background-color: #8B0000;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-border-color: #FFD700;
                               -fx-border-width: 1;
                               -fx-cursor: hand;"
                        onAction="#rendirse"/>
            </HBox>
        </VBox>

        <!-- ============================================ -->
        <!-- ESQUINAS: Jugadores CPU -->
        <!-- ============================================ -->

        <!-- CPU 1 - Esquina Superior Izquierda -->
        <VBox fx:id="panelCPU1" alignment="CENTER" spacing="5"
              AnchorPane.leftAnchor="20" AnchorPane.topAnchor="100"
              visible="false" managed="false">
            <HBox alignment="CENTER" spacing="10">
                <ImageView fx:id="imgFotoCPU1" fitHeight="45" fitWidth="45">
                    <image>
                        <Image url="@/com/example/miniproyecto350zoedadleprabra/images/perfiles/default.png"/>
                    </image>
                </ImageView>
                <Label fx:id="lblNombreCPU1"
                       textFill="#FFD700"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            </HBox>
            <HBox fx:id="manoCPU1" spacing="-30" alignment="CENTER" minHeight="210"/>
            <Label fx:id="lblEstadoCPU1"
                   textFill="#FF0000"
                   style="-fx-font-size: 12px;"/>
        </VBox>

        <!-- CPU 2 - Esquina Superior Derecha -->
        <VBox fx:id="panelCPU2" alignment="CENTER" spacing="5"
              AnchorPane.rightAnchor="20" AnchorPane.topAnchor="100"
              visible="false" managed="false">
            <HBox alignment="CENTER" spacing="10">
                <Label fx:id="lblNombreCPU2"
                       textFill="#FFD700"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <ImageView fx:id="imgFotoCPU2" fitHeight="45" fitWidth="45">
                    <image>
                        <Image url="@/com/example/miniproyecto350zoedadleprabra/images/perfiles/default.png"/>
                    </image>
                </ImageView>
            </HBox>
            <HBox fx:id="manoCPU2" spacing="-30" alignment="CENTER" minHeight="210"/>
            <Label fx:id="lblEstadoCPU2"
                   textFill="#FF0000"
                   style="-fx-font-size: 12px;"/>
        </VBox>

        <!-- CPU 3 - Esquina Inferior Derecha -->
        <VBox fx:id="panelCPU3" alignment="CENTER" spacing="5"
              AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="250"
              visible="false" managed="false">
            <HBox alignment="CENTER" spacing="10">
                <Label fx:id="lblNombreCPU3"
                       textFill="#FFD700"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <ImageView fx:id="imgFotoCPU3" fitHeight="45" fitWidth="45">
                    <image>
                        <Image url="@/com/example/miniproyecto350zoedadleprabra/images/perfiles/default.png"/>
                    </image>
                </ImageView>
            </HBox>
            <HBox fx:id="manoCPU3" spacing="-30" alignment="CENTER" minHeight="210"/>
            <Label fx:id="lblEstadoCPU3"
                   textFill="#FF0000"
                   style="-fx-font-size: 12px;"/>
        </VBox>
    </AnchorPane>
</StackPane>
package com.example.miniproyecto350zoedadleprabra.controller;

import org.junit.jupiter.api.*;
import static org.junit.jupiter.api.Assertions.*;

class CartaTest {

    @Test
    void cartaNormalSumaSuValor() {
        Carta carta = new Carta(Carta.ValorCarta.CINCO, Carta.Palo.CORAZONES);
        assertEquals(5, carta.getValorJuego());
    }

    @Test
    void cartaDiezSumaDiez() {
        Carta carta = new Carta(Carta.ValorCarta.DIEZ, Carta.Palo.TREBOLES);
        assertEquals(10, carta.getValorJuego());
    }

    @Test
    void cartaNueveSumaCero() {
        Carta carta = new Carta(Carta.ValorCarta.NUEVE, Carta.Palo.PICAS);
        assertEquals(0, carta.getValorJuego());
    }

    @Test
    void figuraRestaDiez() {
        Carta j = new Carta(Carta.ValorCarta.J, Carta.Palo.DIAMANTES);
        Carta q = new Carta(Carta.ValorCarta.Q, Carta.Palo.CORAZONES);
        Carta k = new Carta(Carta.ValorCarta.K, Carta.Palo.TREBOLES);

        assertEquals(-10, j.getValorJuego());
        assertEquals(-10, q.getValorJuego());
        assertEquals(-10, k.getValorJuego());
    }

    @Test
    void asPuedeValerUnoODiez() {
        Carta as = new Carta(Carta.ValorCarta.A, Carta.Palo.PICAS);

        // Por defecto usa valor alto
        assertEquals(10, as.getValorJuego());

        // Cambiar a valor bajo
        as.setAsValorAlto(false);
        assertEquals(1, as.getValorJuego());

        // Alternar
        as.alternarValorAs();
        assertEquals(10, as.getValorJuego());
    }

    @Test
    void asEligeMejorValorSegunMesa() {
        Carta as = new Carta(Carta.ValorCarta.A, Carta.Palo.CORAZONES);

        // Con mesa en 45, debe usar 1 (45+10=55 > 50)
        int mejorValor = as.getMejorValorParaJugar(45);
        assertEquals(1, mejorValor);

        // Con mesa en 30, debe usar 10 (30+10=40 <= 50)
        as.setAsValorAlto(false); // resetear
        mejorValor = as.getMejorValorParaJugar(30);
        assertEquals(10, mejorValor);
    }

    @Test
    void cartaPuedeJugarseCorrectamente() {
        Carta cartaAlta = new Carta(Carta.ValorCarta.OCHO, Carta.Palo.PICAS);

        // Con mesa en 40: 40+8=48 <= 50, se puede
        assertTrue(cartaAlta.puedeJugarseConMesa(40));

        // Con mesa en 45: 45+8=53 > 50, no se puede
        assertFalse(cartaAlta.puedeJugarseConMesa(45));
    }

    @Test
    void figurasSiempreSePuedenJugar() {
        Carta k = new Carta(Carta.ValorCarta.K, Carta.Palo.DIAMANTES);

        // Las figuras restan, así que siempre son válidas
        assertTrue(k.puedeJugarseConMesa(50));
        assertTrue(k.puedeJugarseConMesa(100));
    }

    @Test
    void nueveSiempreEsJugable() {
        Carta nueve = new Carta(Carta.ValorCarta.NUEVE, Carta.Palo.TREBOLES);

        // El 9 suma 0, siempre jugable
        assertTrue(nueve.puedeJugarseConMesa(50));
        assertTrue(nueve.puedeJugarseConMesa(0));
    }
}
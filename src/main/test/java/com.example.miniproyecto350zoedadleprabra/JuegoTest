package com.example.miniproyecto350zoedadleprabra.controller;

class JuegoTest {

    private Juego juego;

    @BeforeEach
    void setUp() {
        juego = new Juego(1); // Humano + 1 CPU
        juego.preparar();
    }

    @Test
    void preparacionInicialCorrecta() {
        assertEquals(2, juego.getJugadores().size());

        for (Jugador j : juego.getJugadores()) {
            assertEquals(4, j.getMano().size(), j.getNombre() + " debe tener 4 cartas");
        }

        assertNotNull(juego.getCartaEnMesa());
        assertTrue(juego.getSumaMesa() >= -10 && juego.getSumaMesa() <= 10,
            "La suma inicial debe estar entre -10 y 10");
    }

    @Test
    void jugarCartaValidaActualizaSuma() {
        Jugador jugadorActual = juego.getJugadorActual();
        int sumaAntes = juego.getSumaMesa();

        // Encontrar carta válida
        Optional<Carta> cartaValida = jugadorActual.getMano().stream()
            .filter(c -> c.puedeJugarseConMesa(sumaAntes))
            .findFirst();

        if (cartaValida.isPresent()) {
            assertTrue(juego.jugarCarta(cartaValida.get()));
            assertEquals(sumaAntes + cartaValida.get().getValorJuego(), juego.getSumaMesa());
        }
    }

    @Test
    void cartaInvalidaEsRechazada() {
        int sumaMesa = juego.getSumaMesa();

        // Crear una carta que seguro excede 50
        Carta cartaMuyAlta = new Carta(Carta.ValorCarta.DIEZ, Carta.Palo.PICAS);

        // Si la suma actual + 10 > 50, esta carta no debería ser válida
        if (sumaMesa + 10 > 50) {
            assertFalse(cartaMuyAlta.puedeJugarseConMesa(sumaMesa));
        }
    }

    @Test
    void eliminacionJugadorSinCartasValidas() {
        Jugador jugador = juego.getJugadorActual();

        // Forzar situación donde no puede jugar
        // (Necesitarías manipular la mano y la suma,
        //  esto es más complejo y requiere métodos de test específicos)
    }

    @Test
    void figurasReducenLaSuma() {
        Carta rey = new Carta(Carta.ValorCarta.K, Carta.Palo.DIAMANTES);
        int sumaInicial = 30;

        // Simular que la mesa tiene suma 30
        // y el jugador juega un K (resta 10)
        int sumaEsperada = sumaInicial + rey.getValorJuego();
        assertEquals(20, sumaEsperada);
    }
}